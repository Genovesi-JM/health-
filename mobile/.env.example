# Health Platform Mobile — Environment Variables
#
# Copy this file to .env and fill in your values.
# Expo reads EXPO_PUBLIC_* variables at build time.

# Backend API base URL (no trailing slash)
# Set this to your DigitalOcean backend URL before running:
EXPO_PUBLIC_API_URL=https://api.example.com

# Legacy alias (still supported, EXPO_PUBLIC_API_URL takes precedence)
# EXPO_PUBLIC_API_BASE_URL=https://api.example.com
