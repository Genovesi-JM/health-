# ═══════════════════════════════════════════════════════════════
# Health Platform — Frontend Environment Variables
#
# Dev:        create frontend/.env.local  (git-ignored automatically)
# Production: set as GitHub Actions secret / build arg
#
# NEVER commit a file containing real secrets.
# ═══════════════════════════════════════════════════════════════

# Base URL of the backend API (no trailing slash).
# Dev: leave empty or set to http://localhost:8000 — Vite proxy handles it.
# Production (Docker / DO Droplet): set to '/' — nginx proxies /api/ → backend.
# Production (GitHub Pages + remote API): set to https://api.yourdomain.com
VITE_API_URL=

# Base path for the frontend app (used by Vite router and asset paths).
# GitHub Pages:  /health-/
# Docker / root: /
VITE_BASE_PATH=/health-/
