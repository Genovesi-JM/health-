# ═══════════════════════════════════════════════════════════════
# Health Platform — Backend Environment Variables
#
# Local dev:  copy to backend/.env  →  docker compose up
# Production: set as App/Droplet env vars (DO App Platform or .env on Droplet)
#
# NEVER commit a file containing real values.
# Generate secrets with:  openssl rand -base64 48
# ═══════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────
# dev | staging | production
ENV=dev

# ── Security ─────────────────────────────────────────────────
# REQUIRED in production — generate: openssl rand -base64 48
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRES_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ──────────────────────────────────────────────────
# Local SQLite (dev only):
DATABASE_URL=sqlite:///./health_platform.db
#
# Docker Compose local PostgreSQL:
# DATABASE_URL=postgresql://health_user:changeme@db:5432/health_platform
#
# DigitalOcean Managed PostgreSQL (production — recommended):
# DATABASE_URL=postgresql://doadmin:<password>@<host>.db.ondigitalocean.com:25060/defaultdb?sslmode=require
# Note: DO provides this exact string in the "Connection Details" panel.
# The fix_postgres_url validator in config.py also handles postgres:// → postgresql://

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated. Must include your frontend origin(s).
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── URLs ──────────────────────────────────────────────────────
# Used to build OAuth callbacks and password-reset links (no trailing slash).
FRONTEND_BASE=http://localhost:5173
BACKEND_BASE=http://localhost:8000

# ── Admin Seed Account ────────────────────────────────────────
# Password for the seeded admin account.  Change immediately after first login.
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# ── SMTP (optional — for password reset & notification emails) ─
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com
SMTP_USE_TLS=true

# ── Google OAuth (optional) ───────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── DigitalOcean Spaces (optional — file storage) ─────────────
# Create a Space in your DO account, then generate an access key.
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_BUCKET=health-platform-files
DO_SPACES_REGION=fra1
DO_SPACES_ENDPOINT=https://fra1.digitaloceanspaces.com

# ── Redis (optional — rate-limiting / caching) ────────────────
# Leave empty to disable.  Set to redis://redis:6379/0 for Docker Compose.
REDIS_URL=

# ── OpenAI (optional — AI chatbot) ───────────────────────────
OPENAI_API_KEY=

# ── Stripe (optional — payments) ─────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Encryption (optional — field-level sensitive data) ────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── Docker Compose only (not used by app directly) ────────────
# Password for the local docker-compose PostgreSQL container.
DB_PASSWORD=changeme
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ── Microsoft OAuth (optional) ──
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:8000/auth/microsoft/callback
MICROSOFT_TENANT=common

# ── Email / SMTP (password resets) ──
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=no-reply@healthplatform.com
# SMTP_PASSWORD=your_password
# SMTP_FROM=no-reply@healthplatform.com
# SMTP_USE_TLS=true
